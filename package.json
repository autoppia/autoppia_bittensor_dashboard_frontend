{
  "name": "isomorphic",
  "version": "7.6.2",
  "description": "A nextjs template to build dashboard",
  "private": true,
  "scripts": {
    "dev": "WATCHPACK_POLLING=true CHOKIDAR_USEPOLLING=true turbo dev",
    "lint": "turbo lint",
    "type:check": "turbo type:check",
    "build": "turbo build",
    "build:local": "turbo build:local",
    "build:development": "turbo build:development",
    "build:production": "turbo build:production",
    "start": "turbo start",
    "clean": "turbo clean && rm -rf node_modules .turbo",
    "cache:clean": "turbo cache:clean && rm -rf .turbo",
    "gen-icons": "turbo gen-icons --filter=core",
    "sonar": "./scripts/run-sonar-local.sh",
    "sonar:issues": "./scripts/get-sonar-issues.sh",
    "sonar:fix": "npm run sonar && npm run sonar:issues"
  },
  "devDependencies": {
    "eslint": "9.23.0",
    "prettier": "^3.5.3",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "turbo": "2.4.4",
    "typescript-config": "workspace:*"
  },
  "packageManager": "pnpm@9.1.4",
  "dependencies": {
    "react-icons": "^5.5.0"
  },
  "pnpm": {
    "overrides": {
      "next": ">=15.5.12",
      "minimatch": ">=10.2.3",
      "basic-ftp": ">=5.2.0",
      "glob": ">=11.1.0",
      "@isaacs/brace-expansion": ">=5.0.1"
    }
  }
}
