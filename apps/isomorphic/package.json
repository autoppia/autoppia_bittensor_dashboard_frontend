{
  "name": "starter",
  "version": "7.6.2",
  "private": true,
  "scripts": {
    "dev": "rm -rf .next && ./clean-port.sh && sleep 2 && next dev -p 3000 --turbopack",
    "dev:fast": "./clean-port.sh && sleep 2 && next dev -p 3000 --turbopack",
    "dev:stable": "rm -rf .next && ./clean-port.sh && sleep 2 && next dev -p 3000",
    "dev:polling": "rm -rf .next && ./clean-port.sh && sleep 2 && WATCHPACK_POLLING=true CHOKIDAR_USEPOLLING=true next dev -p 3000 --turbopack",
    "lint": "next lint",
    "build": "rimraf .next/export && next build",
    "build:local": "rimraf .next/export && NEXT_PUBLIC_API_BASE_URL=http://localhost:8080 NEXT_PUBLIC_API_URL=http://localhost:8080 next build",
    "build:development": "rimraf .next/export && NEXT_PUBLIC_API_BASE_URL=https://dev-api-leaderboard.autoppia.com NEXT_PUBLIC_API_URL=https://dev-api-leaderboard.autoppia.com next build",
    "build:production": "rimraf .next/export && NEXT_PUBLIC_API_BASE_URL=https://api-leaderboard.autoppia.com NEXT_PUBLIC_API_URL=https://api-leaderboard.autoppia.com next build",
    "type:check": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "coverage": "vitest run --coverage --passWithNoTests",
    "start": "./clean-port.sh && next build && next start -p 3000",
    "clean": "rm -rf node_modules .next .cache .turbo",
    "cache:clean": "rm -rf .next .cache .turbo"
  },
