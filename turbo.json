{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": ["**/.env.*local"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**"]
    },
    "lint": {},
    "start": {
      "dependsOn": ["^start"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "clean": {
      "dependsOn": ["^clean"]
    },
    "cache:clean": {
      "dependsOn": ["^cache:clean"]
    },
    "gen-icons": {
      "cache": false
    },
    "type:check": {
      "dependsOn": ["^type:check"]
    }
  },
  "ui": "stream"
}
